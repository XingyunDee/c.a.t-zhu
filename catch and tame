--// TOGGLE
local function createToggle(name, key)
    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.new(1, -10, 0, 40)
    Btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Btn.TextColor3 = Color3.new(1,1,1)

    local function update()
        Btn.Text = name .. " : " .. (State[key] and "ON" or "OFF")
    end

    update()

    Btn.MouseButton1Click:Connect(function()
        State[key] = not State[key]
        update()
        Save()
    end)
end

--// TIER SELECTOR
local tiers = {"All","Common","Rare","Epic","Legendary"}

local function createTier(label, key)
    local Btn = Instance.new("TextButton", Frame)
    Btn.Size = UDim2.new(1, -10, 0, 40)
    Btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
    Btn.TextColor3 = Color3.new(1,1,1)

    local index = table.find(tiers, State[key]) or 1

    local function update()
        Btn.Text = label .. " : " .. tiers[index]
        State[key] = tiers[index]
        Save()
    end

    update()

    Btn.MouseButton1Click:Connect(function()
        index = index + 1
        if index > #tiers then index = 1 end
        update()
    end)
end

