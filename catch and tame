--// SAVE / LOAD
local function Save()
    if writefile then
        writefile(FileName, HttpService:JSONEncode(State))
    end
end

local function Load()
    if readfile and isfile and isfile(FileName) then
        local data = HttpService:JSONDecode(readfile(FileName))
        for k,v in pairs(data) do
            State[k] = v
        end
    end
end

